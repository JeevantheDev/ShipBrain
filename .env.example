# ─────────────────────────────────────────────────────────────────────────────
# ShipBrain — Environment Variables
# Copy this file to .env.local and fill in the values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────


# ─── AI Provider ─────────────────────────────────────────────────────────────
# Choose one provider. Azure AI Foundry is the primary (recommended).
# ShipBrain falls back to Google → Anthropic → OpenAI if Foundry is not configured.

LLM_PROVIDER=microsoft_foundry   # microsoft_foundry | anthropic | openai | google

# Azure AI Foundry (primary — required for Foundry IQ knowledge base)
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_ENDPOINT=       # e.g. https://your-resource.services.ai.azure.com
AZURE_AI_FOUNDRY_DEPLOYMENT_NAME=gpt-4.1-mini

# Azure AI Foundry — Project endpoint + knowledge base (RAG grounding)
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=   # e.g. https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_OPENAI_ENDPOINT=               # e.g. https://your-resource.openai.azure.com (used as RAG search endpoint)
AZURE_AI_FOUNDRY_KNOWLEDGE_BASE=     # e.g. shipbrain-knowledgebase740

# Fallback providers (optional — only used if Foundry is not configured)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-3.5-flash


# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # same as ANON_KEY in most projects
SUPABASE_SERVICE_ROLE_KEY=              # server-side only — never expose to browser

# Postgres connection strings (Supabase project settings → Database)
DATABASE_URL=    # pooled connection via pgBouncer — used at runtime
DIRECT_URL=      # direct connection — used for migrations


# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with: repo, workflow, admin:repo_hook scopes
GITHUB_TOKEN=
GITHUB_USERNAME=

# Webhook secret — set the same value in your GitHub webhook configuration
GITHUB_WEBHOOK_SECRET=

# OAuth app (optional — for user GitHub login via Supabase Auth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=


# ─── Application URLs ─────────────────────────────────────────────────────────
# Local dev: http://localhost:3003
# Production: your Vercel or hosting URL
# Webhooks need a public URL — use ngrok in local development

NEXT_PUBLIC_APP_URL=http://localhost:3003
SHIPBRAIN_API_URL=              # public URL for webhook callbacks (ngrok URL in dev)
NEXT_PUBLIC_SHIPBRAIN_API_URL=  # same as SHIPBRAIN_API_URL


# ─── Cloudflare Pages ─────────────────────────────────────────────────────────
# ShipBrain auto-creates Cloudflare Pages projects during repo onboarding.
# Token needs: Account · Cloudflare Pages · Edit permission

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WEBHOOK_SECRET=   # for verifying Cloudflare deploy result callbacks


# ─── Telegram Bot (optional) ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then call /api/telegram/setup
# to register the webhook after the server is running with a public URL.

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_FLUSH_SECRET=


# ─── PagerDuty (optional) ─────────────────────────────────────────────────────
# Used as an incident webhook source. Incidents can also be sent manually
# or via any HTTP POST to /api/webhooks/incidents.

PAGERDUTY_API_TOKEN=
PAGERDUTY_FROM_EMAIL=
PAGERDUTY_API_BASE=https://api.eu.pagerduty.com   # use https://api.pagerduty.com for US
